DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lets_work
REDIS_URL=redis://localhost:6379

# Auth (Better Auth)
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Web app URL — used for CORS and password-reset email links
CORS_ORIGIN=http://localhost:3001

# SMTP (Nodemailer) — e.g. Gmail, SendGrid, Mailtrap, or local Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lets Work <noreply@localhost>"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=replace-with-your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret

NODE_ENV=development
