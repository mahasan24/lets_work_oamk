{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@lets_work/auth": "workspace:*",
    "@lets_work/db": "workspace:*",
    "@lets_work/env": "workspace:*",
    "@lets_work/media": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.45.1",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lets_work/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
