# Production environment for https://letswork.dev
# Copy to /opt/lets_work/.env.production on the VPS (never commit this file).

DOMAIN=letswork.dev

# Public URLs (same-origin: Caddy proxies /api → api container)
BETTER_AUTH_URL=https://letswork.dev
CORS_ORIGIN=https://letswork.dev
VITE_SERVER_URL=https://letswork.dev
VITE_APP_URL=https://letswork.dev

# Postgres (compose injects DATABASE_URL for the api service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=lets_work

# Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Google OAuth (optional)
# Authorized redirect URI: https://letswork.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lets Work <noreply@letswork.dev>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
VITE_CLOUDINARY_CLOUD_NAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

NODE_ENV=production
